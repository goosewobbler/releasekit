{
  "name": "@releasekit/version",
  "version": "0.19.0",
  "description": "Semantic versioning based on Git history and conventional commits",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.ts",
        "default": "./dist/cli.js"
      }
    }
  },
  "bin": {
    "releasekit-version": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage .turbo",
    "test": "vitest run --dir test/unit",
    "test:unit": "vitest run --coverage --dir test/unit",
    "test:integration": "VITEST_INTEGRATION=true vitest run --dir test/integration",
    "test:coverage": "vitest run --coverage --dir test/unit",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "version",
    "semver",
    "git",
    "package"
  ],
  "author": {
    "name": "Sam Maister",
    "email": "goosewobbler@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git",
    "directory": "packages/version"
  },
  "license": "MIT",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@manypkg/get-packages": "^3.1.0",
    "@types/minimatch": "^5.1.2",
    "chalk": "catalog:",
    "commander": "catalog:",
    "conventional-changelog-angular": "^8.3.1",
    "conventional-changelog-conventional-commits": "npm:conventional-changelog-conventionalcommits@^9.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "conventional-commits-filter": "^5.0.0",
    "conventional-recommended-bump": "^11.2.0",
    "figlet": "^1.11.0",
    "git-semver-tags": "^8.0.1",
    "minimatch": "^10.2.5",
    "semver": "catalog:",
    "smol-toml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@releasekit/config": "workspace:*",
    "@releasekit/core": "workspace:*",
    "@types/figlet": "^1.5.5",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
