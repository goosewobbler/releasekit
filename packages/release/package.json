{
  "name": "@releasekit/release",
  "version": "0.13.11",
  "description": "Unified release pipeline: version, changelog, and publish in a single command",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "releasekit": "dist/dispatcher.js",
    "releasekit-release": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage .turbo",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "version",
    "semver",
    "git",
    "package"
  ],
  "author": {
    "name": "Sam Maister",
    "email": "goosewobbler@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git",
    "directory": "packages/release"
  },
  "license": "MIT",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@manypkg/get-packages": "catalog:",
    "@octokit/rest": "catalog:",
    "@releasekit/notes": "workspace:*",
    "@releasekit/publish": "workspace:*",
    "@releasekit/version": "workspace:*",
    "chalk": "catalog:",
    "commander": "catalog:",
    "conventional-changelog-angular": "^8.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "minimatch": "catalog:",
    "smol-toml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@releasekit/config": "workspace:*",
    "@releasekit/core": "workspace:*",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
