{
  "name": "@releasekit/notes",
  "version": "0.3.0-next.2",
  "description": "Release notes and changelog generation with LLM-powered enhancement and flexible templating",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "releasekit-notes": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --dts",
    "clean": "rm -rf dist coverage .turbo",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "changelog",
    "release-notes",
    "llm",
    "template",
    "cli"
  ],
  "author": "Sam Maister <goosewobbler@protonmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git",
    "directory": "packages/notes"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@octokit/rest": "^22.0.1",
    "@releasekit/config": "workspace:*",
    "@releasekit/core": "workspace:*",
    "chalk": "catalog:",
    "commander": "catalog:",
    "ejs": "^4.0.1",
    "handlebars": "^4.7.8",
    "liquidjs": "^10.25.0",
    "openai": "^6.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/ejs": "^3.1.5",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
