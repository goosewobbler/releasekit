{
  "name": "@releasekit/publish",
  "version": "0.22.0",
  "description": "Publish packages to npm and crates.io with git tagging and GitHub releases",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.ts",
        "default": "./dist/cli.js"
      }
    }
  },
  "bin": {
    "releasekit-publish": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage .turbo",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "publish",
    "npm",
    "cargo",
    "release",
    "ci"
  ],
  "author": {
    "name": "Sam Maister",
    "email": "goosewobbler@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git",
    "directory": "packages/publish"
  },
  "license": "MIT",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "catalog:",
    "commander": "catalog:",
    "minimatch": "catalog:",
    "semver": "catalog:",
    "smol-toml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@releasekit/config": "workspace:*",
    "@releasekit/core": "workspace:*",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "npm-packlist": "^10.0.4",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.17"
  }
}
