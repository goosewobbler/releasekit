{
  "name": "@releasekit/publish",
  "version": "0.1.0",
  "description": "CLI tool for publishing packages to npm and crates.io with git tagging and GitHub releases",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "releasekit-publish": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --watch --dts",
    "clean": "rm -rf dist coverage .turbo",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["publish", "npm", "cargo", "release", "ci"],
  "author": {
    "name": "Sam Maister",
    "email": "goosewobbler@protonmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git",
    "directory": "packages/publish"
  },
  "license": "MIT",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@releasekit/config": "workspace:*",
    "@releasekit/core": "workspace:*",
    "chalk": "catalog:",
    "commander": "catalog:",
    "semver": "catalog:",
    "smol-toml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18 || >=20"
  }
}
