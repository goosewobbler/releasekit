{%- comment -%}
Release notes template.
Categories are pre-ordered by the pipeline (New → Fixed → Changed → Removed → Documentation → Developer).
Developer entries use bolded subcategory labels.
{%- endcomment -%}
{%- for version in versions %}
{%- if version.enhanced.categories %}
{%- for cat in version.enhanced.categories %}
{%- if cat.entries.size > 0 %}

### {{ cat.name }}:
{%- for entry in cat.entries %}
{%- if entry.scope %}
- **{{ entry.scope }}**: {{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- else %}
- {{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- else %}
{%- comment -%}Fallback: no LLM categories, use conventional commit types{%- endcomment -%}
{%- assign added = version.entries | where: "type", "added" %}
{%- assign fixed = version.entries | where: "type", "fixed" %}
{%- assign changed = version.entries | where: "type", "changed" %}
{%- assign removed = version.entries | where: "type", "removed" %}
{%- if added.size > 0 %}

### New:
{%- for entry in added %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if fixed.size > 0 %}

### Fixed:
{%- for entry in fixed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if changed.size > 0 %}

### Changed:
{%- for entry in changed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if removed.size > 0 %}

### Removed:
{%- for entry in removed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if version.compareUrl %}

**Full Changelog**: {{ version.compareUrl }}
{%- endif %}
{% endfor %}
