{%- comment -%}
Release notes template matching wdio-electron-service format.
Categories are ordered: New → Fixed → Changed → Removed → Documentation → Developer
Developer entries use bolded subcategory labels.
{%- endcomment -%}
{%- for version in versions %}
{%- if version.enhanced.categories %}
{%- comment -%}Define category order{%- endcomment -%}
{%- assign ordered_categories = "New,Fixed,Changed,Removed,Documentation,Developer" | split: "," %}
{%- comment -%}Build a lookup map{%- endcomment -%}
{%- assign category_map = "" %}
{%- for pair in version.enhanced.categories %}
{%- assign category_name = pair[0] %}
{%- assign category_entries = pair[1] %}
{%- endfor %}
{%- comment -%}Output categories in order{%- endcomment -%}
{%- for cat_name in ordered_categories %}
{%- for pair in version.enhanced.categories %}
{%- if pair[0] == cat_name %}
{%- assign entries = pair[1] %}
{%- if entries.size > 0 %}

### {{ cat_name }}:
{%- for entry in entries %}
{%- if cat_name == "Developer" and entry.scope %}
- **{{ entry.scope }}**: {{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- elsif entry.scope %}
- **{{ entry.scope }}**: {{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- else %}
- {{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- endfor %}
{%- endfor %}
{%- else %}
{%- comment -%}Fallback to conventional commit types with custom ordering{%- endcomment -%}
{%- assign added = version.entries | where: "type", "added" %}
{%- assign fixed = version.entries | where: "type", "fixed" %}
{%- assign changed = version.entries | where: "type", "changed" %}
{%- assign removed = version.entries | where: "type", "removed" %}
{%- if added.size > 0 %}

### New:
{%- for entry in added %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if fixed.size > 0 %}

### Fixed:
{%- for entry in fixed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if changed.size > 0 %}

### Changed:
{%- for entry in changed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- if removed.size > 0 %}

### Removed:
{%- for entry in removed %}
- {% if entry.scope %}**{{ entry.scope }}**: {% endif %}{{ entry.description }}{% if entry.issueIds %} ({{ entry.issueIds | join: ", " }}){% endif %}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if version.compareUrl %}

**Full Changelog**: {{ version.compareUrl }}
{%- endif %}
{% endfor %}
