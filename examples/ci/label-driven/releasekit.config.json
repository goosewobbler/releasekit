{
  "$schema": "https://goosewobbler.github.io/releasekit/schema.json",
  "git": {
    "branch": "main"
  },
  "version": {
    "preset": "angular"
  },
  "publish": {
    "npm": {
      "enabled": true,
      "access": "public"
    }
  },
  "ci": {
    "releaseStrategy": "direct",
    "releaseTrigger": "label",
    "labels": {
      "major": "bump:major",
      "minor": "bump:minor",
      "patch": "bump:patch",
      "skip": "release:skip"
    }
  }
}
