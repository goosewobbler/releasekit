{
  "name": "releasekit-monorepo",
  "version": "0.19.2",
  "private": true,
  "type": "module",
  "description": "Release tooling for automated versioning and changelog generation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goosewobbler/releasekit.git"
  },
  "license": "MIT",
  "author": "Sam Maister <goosewobbler@protonmail.com>",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.12.0"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:coverage": "turbo run test:coverage",
    "test:harness": "node scripts/test-harness/index.mjs",
    "test:action": "node scripts/test-harness/index.mjs",
    "test:action:preview": "node scripts/test-harness/index.mjs preview",
    "test:action:release": "node scripts/test-harness/index.mjs release --bump patch",
    "lint": "biome check --formatter-enabled=false --linter-enabled=true . && eslint --cache \"packages/**/*.ts\"",
    "lint:fix": "biome check --write --formatter-enabled=false --linter-enabled=true .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:cache": "turbo daemon stop && rm -rf .turbo .eslintcache",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "turbo": "2.9.6",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "**/*.ts": [
      "biome check --write",
      "eslint --fix --cache"
    ],
    "**/*.{md,json}": [
      "biome format --write"
    ]
  }
}
