{
  "preset": "angular",
  "sync": false,
  "baseBranch": "main",
  "versionPrefix": "v",
  "packages": ["packages/version", "packages/notes"],
  "tagTemplate": "${packageName}@v${version}",
  "commitMessage": "chore: release ${packageName}@${version} [skip ci]",
  "changelogFormat": "keep-a-changelog",
  "prereleaseIdentifier": "next"
}
